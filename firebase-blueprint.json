{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the application",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique identifier"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL"
        },
        "history": {
          "type": "array",
          "description": "The user's search and view history",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["search", "view_expediente", "view_legislador"]
              },
              "query": {
                "type": "string"
              },
              "timestamp": {
                "type": "number"
              }
            }
          }
        },
        "interests": {
          "type": "array",
          "description": "The user's topics of interest",
          "items": {
            "type": "string"
          }
        }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles, history, and interests"
    }
  }
}
